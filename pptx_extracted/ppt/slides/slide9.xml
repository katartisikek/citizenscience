lidFill><a:latin typeface="Open Sans" pitchFamily="34" charset="0"/><a:ea typeface="Open Sans" pitchFamily="34" charset="-122"/><a:cs typeface="Open Sans" pitchFamily="34" charset="-120"/></a:rPr><a:t>Trust in science is built through openness, dialogue, and shared experience — not simply through authority or credentials. When citizens observe how data is collected, analysed, and communicated, research becomes more understandable and credible. Institutions are no longer distant, invisible authorities; they become visible partners working alongside communities.</a:t></a:r><a:endParaRPr lang="en-US" sz="950" dirty="0"/></a:p></p:txBody></p:sp><p:sp><p:nvSpPr><p:cNvPr id="4" name="Shape 2"></p:cNvPr><p:cNvSpPr/><p:nvPr></p:nvPr></p:nvSpPr><p:spPr><a:xfrm><a:off x="406822" y="2158603"/><a:ext cx="4103191" cy="2196778"/></a:xfrm><a:prstGeom prst="roundRect"><a:avLst><a:gd name="adj" fmla="val 4066"/></a:avLst></a:prstGeom><a:solidFill><a:srgbClr val="835E54"/></a:solidFill><a:ln></a:ln></p:spPr></p:sp><p:sp><p:nvSpPr><p:cNvPr id="5" name="Text 3"></p:cNvPr><p:cNvSpPr/><p:nvPr></p:nvPr></p:nvSpPr><p:spPr><a:xfrm><a:off x="530796" y="2282577"/><a:ext cx="2007766" cy="193849"/></a:xfrm><a:prstGeom prst="rect"><a:avLst></a:avLst></a:prstGeom><a:noFill/><a:ln></a:ln></p:spPr><p:txBody><a:bodyPr wrap="none" lIns="0" tIns="0" rIns="0" bIns="0" rtlCol="0" anchor="t"></a:bodyPr><a:lstStyle/><a:p><a:pPr algn="l" indent="0" marL="0"><a:lnSpc><a:spcPct val="104000"/></a:lnSpc><a:buNone/></a:pPr><a:r><a:rPr lang="en-US" sz="1200" b="1" dirty="0"><a:solidFill><a:srgbClr val="FFFFFF"/></a:solidFill><a:latin typeface="Crimson Pro Bold" pitchFamily="34" charset="0"/><a:ea typeface="Crimson Pro Bold" pitchFamily="34" charset="-122"/><a:cs typeface="Crimson Pro Bold" pitchFamily="34" charset="-120"/></a:rPr><a:t>What Creates Trust</a:t></a:r><a:endParaRPr lang="en-US" sz="1200" dirty="0"/></a:p></p:txBody></p:sp><p:sp><p:nvSpPr><p:cNvPr id="6" name="Text 4"></p:cNvPr><p:cNvSpPr/><p:nvPr></p:nvPr></p:nvSpPr><p:spPr><a:xfrm><a:off x="530796" y="2600399"/><a:ext cx="3855244" cy="1165845"/></a:xfrm><a:prstGeom prst="rect"><a:avLst></a:avLst></a:prstGeom><a:noFill/><a:ln></a:ln></p:spPr><p:txBody><a:bodyPr wrap="square" lIns="0" tIns="0" rIns="0" bIns="0" rtlCol="0" anchor="t"><a:normAutofit/></a:bodyPr><a:lstStyle/><a:p><a:pPr algn="l" marL="193040" indent="-193040"><a:lnSpc><a:spcPct val="133000"/></a:lnSpc><a:buSzPct val="100000"/><a:buChar char="&#x2022;"/></a:pPr><a:r><a:rPr lang="en-US" sz="950" dirty="0"><a:solidFill><a:srgbClr val="FFFFFF"/></a:solidFill><a:latin typeface="Open Sans" pitchFamily="34" charset="0"/><a:ea typeface="Open Sans" pitchFamily="34" charset="-122"/><a:cs typeface="Open Sans" pitchFamily="34" charset="-120"/></a:rPr><a:t>Direct contact between citizens and researchers</a:t></a:r><a:endParaRPr lang="en-US" sz="950" dirty="0"/></a:p><a:p><a:pPr algn="l" marL="193040" indent="-193040"><a:lnSpc><a:spcPct val="133000"/></a:lnSpc><a:buSzPct val="100000"/><a:buChar char="&#x2022;"/></a:pPr><a:r><a:rPr lang="en-US" sz="950" dirty="0"><a:solidFill><a:srgbClr val="FFFFFF"/></a:solidFill><a:latin typeface="Open Sans" pitchFamily="34" charset="0"/><a:ea typeface="Open Sans" pitchFamily="34" charset="-122"/><a:cs typeface="Open Sans" pitchFamily="34" charset="-120"/></a:rPr><a:t>Transparency in methods and results</a:t></a:r><a:endParaRPr lang="en-US" sz="950" dirty="0"/></a:p><a:p><a:pPr algn="l" marL="193040" indent="-193040"><a:lnSpc><a:spcPct val="133000"/></a:lnSpc><a:buSzPct val="100000"/><a:buChar char="&#x2022;"/></a:pPr><a:r><a:rPr lang="en-US" sz="950" dirty="0"><a:solidFill><a:srgbClr val="FFFFFF"/></a:solidFill><a:latin typeface="Open Sans" pitchFamily="34" charset="0"/><a:ea typeface="Open Sans" pitchFamily="34" charset="-122"/><a:cs typeface="Open Sans" pitchFamily="34" charset="-120"/></a:rPr><a:t>Open access to data where possible</a:t></a:r><a:endParaRPr lang="en-US" sz="950" dirty="0"/></a:p><a:p><a:pPr algn="l" marL="193040" indent="-193040"><a:lnSpc><a:spcPct val="133000"/></a:lnSpc><a:buSzPct val="100000"/><a:buChar char="&#x2022;"/></a:pPr><a:r><a:rPr lang="en-US" sz="950" dirty="0"><a:solidFill><a:srgbClr val="FFFFFF"/></a:solidFill><a:latin typeface="Open Sans" pitchFamily="34" charset="0"/><a:ea typeface="Open Sans" pitchFamily="34" charset="-122"/><a:cs typeface="Open Sans" pitchFamily="34" charset="-120"/></a:rPr><a:t>Visible, tangible local benefits</a:t></a:r><a:endParaRPr lang="en-US" sz="950" dirty="0"/></a:p><a:p><a:pPr algn="l" marL="193040" indent="-193040"><a:lnSpc><a:spcPct val="133000"/></a:lnSpc><a:buSzPct val="100000"/><a:buChar char="&#x2022;"/></a:pPr><a:r><a:rPr lang="en-US" sz="950" dirty="0"><a:solidFill><a:srgbClr val="FFFFFF"/></a:solidFill><a:latin typeface="Open Sans" pitchFamily="34" charset="0"/><a:ea typeface="Open Sans" pitchFamily="34" charset="-122"/><a:cs typeface="Open Sans" pitchFamily="34" charset="-120"/></a:rPr><a:t>Shared responsibility for findings</a:t></a:r><a:endParaRPr lang="en-US" sz="950" dirty="0"/></a:p></p:txBody></p:sp><p:sp><p:nvSpPr><p:cNvPr id="7" name="Text 5"></p:cNvPr><p:cNvSpPr/><p:nvPr></p:nvPr></p:nvSpPr><p:spPr><a:xfrm><a:off x="4728046" y="2282577"/><a:ext cx="2007766" cy="193849"/></a:xfrm><a:prstGeom prst="rect"><a:avLst></a:avLst></a:prstGeom><a:noFill/><a:ln></a:ln></p:spPr><p:txBody><a:bodyPr wrap="none" lIns="0" tIns="0" rIns="0" bIns="0" rtlCol="0" anchor="t"></a:bodyPr><a:lstStyle/><a:p><a:pPr algn="l" indent="0" marL="0"><a:lnSpc><a:spcPct val="104000"/></a:lnSpc><a:buNone/></a:pPr><a:r><a:rPr lang="en-US" sz="1200" b="1" dirty="0"><a:solidFill><a:srgbClr val="443728"/></a:solidFill><a:latin typeface="Crimson Pro Bold" pitchFamily="34" charset="0"/><a:ea typeface="Crimson Pro Bold" pitchFamily="34" charset="-122"/><a:cs typeface="Crimson Pro Bold" pitchFamily="34" charset="-120"/></a:rPr><a:t>Why It Matters</a:t></a:r><a:endParaRPr lang="en-US" sz="1200" dirty="0"/></a:p></p:txBody></p:sp><p:sp><p:nvSpPr><p:cNvPr id="8" name="Text 6"></p:cNvPr><p:cNvSpPr/><p:nvPr></p:nvPr></p:nvSpPr><p:spPr><a:xfrm><a:off x="4728046" y="2600399"/><a:ext cx="3924598" cy="793849"/></a:xfrm><a:prstGeom prst="rect"><a:avLst></a:avLst></a:prstGeom><a:noFill/><a:ln></a:ln></p:spPr><p:txBody><a:bodyPr wrap="square" lIns="0" tIns="0" rIns="0" bIns="0" rtlCol="0" anchor="t"><a:normAutofit/></a:bodyPr><a:lstStyle/><a:p><a:pPr algn="l" indent="0" marL="0"><a:lnSpc><a:spcPct val="133000"/></a:lnSpc><a:buNone/></a:pPr><a:r><a:rPr lang="en-US" sz="950" dirty="0"><a:solidFill><a:srgbClr val="443728"/></a:solidFill><a:latin typeface="Open Sans" pitchFamily="34" charset="0"/><a:ea typeface="Open Sans" pitchFamily="34" charset="-122"/><a:cs typeface="Open Sans" pitchFamily="34" charset="-120"/></a:rPr><a:t>This is especially critical for public health and environmental issues, where trust directly affects participation, preventive behaviour, and acceptance of evidence-based policy. A community that trusts the science is a community that acts on it.</a:t></a:r><a:endParaRPr lang="en-US" sz="950" dirty="0"/></a:p></p:txBody></p:sp><p:sp><p:nvSpPr><p:cNvPr id="9" name="Shape 7"></p:cNvPr><p:cNvSpPr/><p:nvPr></p:nvPr></p:nvSpPr><p:spPr><a:xfrm><a:off x="4728046" y="3533775"/><a:ext cx="3924598" cy="682079"/></a:xfrm><a:prstGeom prst="roundRect"><a:avLst><a:gd name="adj" fmla="val 7638"/></a:avLst></a:prstGeom><a:solidFill><a:srgbClr val="EBE2E0"/></a:solidFill><a:ln></a:ln></p:spPr></p:sp><p:pic>  <p:nvPicPr><p:cNvPr id="10" name="Image 0" descr="preencoded.png">    </p:cNvPr>    <p:cNvPicPr><a:picLocks noChangeAspect="1"/></p:cNvPicPr>    <p:nvPr></p:nvPr>  </p:nvPicPr><p:blipFill><a:blip r:embed="rId1"></a:blip>  <a:stretch><a:fillRect/></a:stretch></p:blipFill><p:spPr> <a:xfrm>  <a:off x="4852020" y="3723084"/>  <a:ext cx="155004" cy="123974"/> </a:xfrm> <a:prstGeom prst="rect"><a:avLst/></a:prstGeom></p:spPr></p:pic><p:sp><p:nvSpPr><p:cNvPr id="11" name="Text 8"></p:cNvPr><p:cNvSpPr/><p:nvPr></p:nvPr></p:nvSpPr><p:spPr><a:xfrm><a:off x="5130998" y="3676352"/><a:ext cx="3397672" cy="396925"/></a:xfrm><a:prstGeom prst="rect"><a:avLst></a:avLst></a:prstGeom><a:noFill/><a:ln></a:ln></p:spPr><p:txBody><a:bodyPr wrap="square" lIns="0" tIns="0" rIns="0" bIns="0" rtlCol="0" anchor="t"><a:normAutofit/></a:bodyPr><a:lstStyle/><a:p><a:pPr algn="l" indent="0" marL="0"><a:lnSpc><a:spcPct val="133000"/></a:lnSpc><a:buNone/></a:pPr><a:r><a:rPr lang="en-US" sz="950" dirty="0"><a:solidFill><a:srgbClr val="000000"/></a:solidFill><a:latin typeface="Open Sans" pitchFamily="34" charset="0"/><a:ea typeface="Open Sans" pitchFamily="34" charset="-122"/><a:cs typeface="Open Sans" pitchFamily="34" charset="-120"/></a:rPr><a:t>Trust is not given — it is built through transparency and collaboration.</a:t></a:r><a:endParaRPr lang="en-US" sz="950" dirty="0"/></a:p></p:txBody></p:sp></p:spTree></p:cSld><p:clrMapOvr><a:masterClrMapping/></p:clrMapOvr></p:sld>